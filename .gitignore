!.gitkeep

# Raw live-browser observations carry session-local identifiers and are not
# publication evidence. Keep only the bounded evaluator reports referenced by
# the release documents.
artifacts/live-eval/*/
!artifacts/live-eval/20260715-222618/
artifacts/live-eval/20260715-222618/*
!artifacts/live-eval/20260715-222618/report.edn

artifacts/evolution-eval/*/
!artifacts/evolution-eval/20260715-234942/
artifacts/evolution-eval/20260715-234942/*
!artifacts/evolution-eval/20260715-234942/report.edn
!artifacts/evolution-eval/20260716-141959/
artifacts/evolution-eval/20260716-141959/*
!artifacts/evolution-eval/20260716-141959/report.edn

artifacts/demo-live/*/
!artifacts/demo-live/20260717-060709/
artifacts/demo-live/20260717-060709/*
!artifacts/demo-live/20260717-060709/report.edn

# Raw and edited video captures stay local until the owner authorizes upload.
artifacts/demo-capture/
artifacts/submission-video/

artifacts/demo/*/
!artifacts/demo/20260716-004803/
artifacts/demo/20260716-004803/*
!artifacts/demo/20260716-004803/report.edn

artifacts/**/observations.json
artifacts/**/.last-run.json

# Codex credentials and local provider output are never repository data.
.codex/
auth.json
*.jsonl

.gstack/
